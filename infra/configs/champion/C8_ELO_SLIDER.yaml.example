# Champion mode config for C8_ELO_SLIDER.

task_id: C8_ELO_SLIDER
baseline_branch: main
canonical_branch: main
candidate_root: ../worktrees
report_root: reports/comparisons
parallel_jobs: 4
command_timeout_seconds: 240

test_commands:
  - "{python} infra/scripts/run_milestone_tests.py --task C8_ELO_SLIDER"

score_weights:
  correctness_tests: 35
  code_review_quality: 20
  interface_compatibility: 15
  performance_engine_impact: 15
  cost_time_efficiency: 10
  documentation_report_quality: 5

candidates:
  - candidate_id: C8_codex_agent
    task_id: C8_ELO_SLIDER
    orchestration_type: codex_agent
    model_assignments: {builder: codex, reviewer: codex}
    execution_environment: codex_execution
    branch_name: experiments/C8/codex_agent
    worktree_path: ../worktrees/C8-codex-agent
    allowed_tools: [repo_edit, pytest, git_diff]
    budget: {max_minutes: 90, max_cost_usd: 20}
    output_report_path: reports/tasks/C8_codex_agent.md
    notes: Codex candidate for approximate Elo/strength slider.

  - candidate_id: C8_rlm_openai
    task_id: C8_ELO_SLIDER
    orchestration_type: rlm
    model_assignments: {recursive_agent: openai, methodology_reference: alexzhang13/rlm}
    execution_environment: local_worktree
    branch_name: experiments/C8/rlm_openai
    worktree_path: ../worktrees/C8-rlm-openai
    orchestration_command: "{python} -m methodologies.rlm.runner --task {milestone_task_id} --candidate-id {candidate_id} --mode {orchestration_mode} --output-root reports/orchestration --task-root infra/tasks"
    allowed_tools: [repo_edit, pytest, git_diff, rlm_repl]
    budget: {max_minutes: 120, max_cost_usd: 40}
    output_report_path: reports/tasks/C8_rlm_openai.md
    notes: Recursive Language Model candidate; audit mode is no-secrets, live mode calls RLM.

  - candidate_id: C8_replit_agent
    task_id: C8_ELO_SLIDER
    orchestration_type: replit_agent
    model_assignments: {builder: replit_agent}
    execution_environment: replit_external
    branch_name: experiments/C8/replit_agent
    worktree_path: ../worktrees/C8-replit-agent
    allowed_tools: [repo_edit, pytest, git_diff]
    budget: {max_minutes: 120, max_cost_usd: 20}
    output_report_path: reports/tasks/C8_replit_agent.md
    notes: Replit-generated branch evaluated by Champion mode.

  - candidate_id: C8_custom_parallel
    task_id: C8_ELO_SLIDER
    orchestration_type: custom_langchain_parallel
    model_assignments: {planner: gpt, builder: claude, reviewer: gemini}
    execution_environment: local_worktree
    branch_name: experiments/C8/custom_parallel
    worktree_path: ../worktrees/C8-custom-parallel
    allowed_tools: [repo_edit, pytest, git_diff]
    budget: {max_minutes: 120, max_cost_usd: 40}
    output_report_path: reports/tasks/C8_custom_parallel.md
    notes: Custom parallel multi-model candidate.
